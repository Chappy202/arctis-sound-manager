{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arctis Sound Manager",
  "version": "0.2.3",
  "identifier": "com.oxibux.arctis-sound-manager",
  "build": {
    "beforeDevCommand": "pnpm --dir frontend dev",
    "beforeBuildCommand": "pnpm --dir frontend build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Arctis Sound Manager",
        "width": 1100,
        "height": 720,
        "minWidth": 920,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["rpm", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/asm-cli"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Chappy202/arctis-sound-manager/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2QjBGRUZEMTVDRUFBQkQKUldTOXFzNFYvZjZ3OWllNW9XVURUc0dlcGVHZ1ErM2VNMkRjOTFrUFRNcU5vNWZzNVR4L3ljNkkK"
    }
  }
}
