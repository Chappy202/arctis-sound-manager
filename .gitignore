/target
**/*.rs.bk
*.pdb

# Harness scratch — keep project commands/skills, ignore everything else
# (worktrees = large repo clones, plus any local settings/transcripts).
.claude/*
!.claude/commands/
!.claude/skills/
.superpowers/

# Tauri updater signing private key — NEVER commit; store in CI secret TAURI_SIGNING_PRIVATE_KEY
*.key
# But allow the public key to be committed if placed in the repo
!*.key.pub
.signing/
/node_modules/

# Local build artifacts / scratch — never commit
*.rpm
